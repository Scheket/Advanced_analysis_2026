clear; close all; clc; 
%%
% Open the access to the folder with the data to load

addpath('/home/liza/Documents/Technion/Advanced_Analysis_26/Advanced_analysis_2026/1st_lesson');
%%
% Load data as a table (column names and values)

filename = "penguins.csv";
penguins = readtable(filename); % analog of pandas dataframe in python
%%
% Fast data summary

summary(penguins); %[output:301e70a8]
%%
% Statistics for the column vector to the structure

stats = datastats(penguins.body_mass_g)  %[output:373bb2c5]
%%
% Preprocessing the variable types

penguins.species = categorical(penguins.species);
penguins.island = categorical(penguins.island);
penguins.sex = categorical(penguins.sex);
%%
% Cleaning from the missing values

penguins1 = rmmissing(penguins);
%%
summary(penguins1) %[output:57b0dac1]
%%
% The whole sample histogram for the bill length

histogram(penguins1.bill_length_mm,"DisplayStyle","bar"); %[output:0cef566a]

xlabel("Bill Length, mm") %[output:0cef566a]
ylabel("Frequency") %[output:0cef566a]
%%
% Slicing the data

gentoo = penguins1(penguins1.species == "Gentoo",:); 
chinstrap = penguins1(penguins1.species == "Chinstrap",:);
adelie = penguins1(penguins1.species == "Adelie",:);
%%
% Different species histogram

h(1) = histogram(gentoo.flipper_length_mm, "FaceAlpha",0.5, SeriesIndex=1); %[output:738c717a]
hold on %[output:738c717a]
h(2) = histogram(chinstrap.flipper_length_mm, "FaceAlpha",0.5, SeriesIndex=2); %[output:738c717a]
h(3) = histogram(adelie.flipper_length_mm, "FaceAlpha",0.5, SeriesIndex=4); %[output:738c717a]
hold off  %[output:738c717a]
xlabel("Flipper length (mm)") %[output:738c717a]
ylabel("Frequency") %[output:738c717a]
legend(h,"Gentoo", "Chinstrap", "Adelie") %[output:738c717a]
%%
% BOXPLOT

figure; %[output:8cbfc20a]
boxchart(penguins1.species, penguins1.flipper_length_mm) %[output:8cbfc20a]
ylabel("Flipper Length (mm)") %[output:8cbfc20a]
%%
% MIN & MAX on the histogram

histogram(penguins1.flipper_length_mm) %[output:1d6ff9a7]
xlabel("Flipper Length (mm)") %[output:1d6ff9a7]
ylabel("Frequency") %[output:1d6ff9a7]
title("Distribution of penguin flipper lengths") %[output:1d6ff9a7]

min_flip = min(penguins1.flipper_length_mm) %[output:9fe1ec2e]
xline(min_flip, "LineWidth",5) %[output:1d6ff9a7]

max_flip = max(penguins1.flipper_length_mm) %[output:99670045]
xline(max_flip, "LineWidth",5) %[output:1d6ff9a7]
%%
% Mean, Meadian, Mode

histogram(penguins1.flipper_length_mm, "EdgeColor","none") % you can remove the edges by utilzing the "EdgeColor" option %[output:6c1b82e4]
xlabel("Flipper Length (mm)") %[output:6c1b82e4]
ylabel("Frequency") %[output:6c1b82e4]
title("Distribution of penguin flipper lengths") %[output:6c1b82e4]

mean_flip = mean(penguins1.flipper_length_mm) %[output:874caac3]
xline(mean_flip, "--") %[output:6c1b82e4]

median_flip = median(penguins1.flipper_length_mm) %[output:469217ae]
xline(median_flip, ":", "LineWidth",1.5) %[output:6c1b82e4]

mode_flip = mode(penguins1.flipper_length_mm) %[output:72bb433a]
xline(mode_flip, "-.", 'LineWidth',2) %[output:6c1b82e4]
legend ("flip length", "mean", "median", "mode") %[output:6c1b82e4]
%%
% Hypothesis testing

male = penguins1(penguins1.sex == "MALE",:);
female = penguins1(penguins1.sex == "FEMALE",:);
%%
class(penguins1.body_mass_g) %[output:6e74b1a0]
%%
% Look on the hypothesis in boxplot

boxchart(penguins1.sex, penguins1.body_mass_g) % plot body mass, broken up by sex  %[output:458a4648]
xlabel("Sex") %[output:458a4648]
ylabel("Body Mass (g)") %[output:458a4648]
%%
[h, p] = ttest2(male.body_mass_g, female.body_mass_g) %[output:2ce2179e] %[output:3e9bff88]
%%
[h, p] = ttest2(male.bill_length_mm, female.bill_length_mm, "Tail", "right") %[output:6fbd86aa] %[output:48129e08]
%%
%%%%% --- Q1 --- %%%%%

% Load data
penguins = readtable('penguins.csv');
penguins = rmmissing(penguins);

% Filter Chinstrap penguins
chinstrap = penguins(strcmp(penguins.species, 'Chinstrap'), :);
% Filter Adelie penguins
adelie = penguins(strcmp(penguins.species, 'Adelie'), :);


% Requested Histogram
figure %[output:7f22227a]
h(1) = histogram(chinstrap.body_mass_g, 'FaceAlpha', 0.5, SeriesIndex=2); %[output:7f22227a]

%%%%% --- Q2 --- %%%%%
hold on %[output:7f22227a]
% Requested Histogram for Adelie
h(2) = histogram(adelie.body_mass_g, 'FaceAlpha', 0.3, SeriesIndex=4); %[output:7f22227a]

%%%%% --- Q3 --- %%%%%
hold off %[output:7f22227a]

%%%%% --- Q4 --- %%%%%
xlabel('Body Mass (g)') %[output:7f22227a]
ylabel('Frequency') %[output:7f22227a]
title('Comparison of Body Mass: Chinstrap and Adelie Penguins') %[output:7f22227a]

%%%%% --- Q5 --- %%%%%
legend('Chinstrap', 'Adelie') %[output:7f22227a]


